{%- liquid
  assign s = section.settings
-%}

<div
  class="hl-bundles hl-section color-{{ s.color_scheme }}"
  style="--hl-pt: {{ s.padding_top }}px; --hl-pb: {{ s.padding_bottom }}px;"
>
  <div class="hl-container">
    <div class="hl-section__head hl-section__head--center">
      {%- if s.eyebrow != blank -%}<span class="hl-eyebrow" data-hl-reveal>{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="hl-heading hl-heading--lg" data-hl-reveal>{{ s.heading }}</h2>{%- endif -%}
    </div>

    <div class="hl-bundles__grid">
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}
        <article class="hl-bundles__card" data-hl-reveal style="--hl-reveal-delay: {{ forloop.index0 | times: 90 }}ms;" {{ block.shopify_attributes }}>
          <div class="hl-bundles__media">
            {%- if b.image != blank -%}
              {{ b.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400,600,800,1000', sizes: '(min-width:750px) 45vw, 100vw', class: 'hl-bundles__img', alt: b.title }}
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'hl-bundles__img' }}
            {%- endif -%}
            {%- if b.badge != blank -%}<span class="hl-bundles__badge">{{ b.badge }}</span>{%- endif -%}
          </div>
          <div class="hl-bundles__body">
            <h3 class="hl-heading hl-heading--md">{{ b.title }}</h3>
            {%- if b.items != blank -%}<div class="hl-bundles__items hl-text">{{ b.items }}</div>{%- endif -%}
            <div class="hl-bundles__pricing">
              {%- if b.price != blank -%}<span class="hl-bundles__price">{{ b.price }}</span>{%- endif -%}
              {%- if b.compare_price != blank -%}<s class="hl-bundles__compare">{{ b.compare_price }}</s>{%- endif -%}
            </div>
            {%- if b.button_label != blank -%}
              <a class="hl-btn hl-btn--primary hl-bundles__btn" href="{{ b.button_link | default: '#' }}">{{ b.button_label }}</a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hl-bundles__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(20px, 3vw, 40px);
  }

  .hl-bundles__card {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--hl-radius-lg);
    overflow: hidden;
    box-shadow: var(--hl-shadow-sm);
    transition: transform 0.4s var(--hl-ease), box-shadow 0.4s var(--hl-ease);
  }

  .hl-bundles__card:hover { transform: translateY(-6px); box-shadow: var(--hl-shadow-md); }

  .hl-bundles__media { position: relative; }
  .hl-bundles__img { width: 100%; height: 100%; object-fit: cover; min-height: 220px; }

  .hl-bundles__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: var(--hl-green);
    color: #fff;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.8rem;
    padding: 0.4rem 0.85rem;
    border-radius: var(--hl-radius-pill);
  }

  .hl-bundles__body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: clamp(20px, 2.2vw, 34px);
    align-items: flex-start;
  }

  .hl-bundles__items { font-size: 0.95rem; opacity: 0.8; }
  .hl-bundles__items :is(ul, ol) { margin: 0; padding-left: 1.1rem; }
  .hl-bundles__items p { margin: 0; }

  .hl-bundles__pricing { display: flex; align-items: baseline; gap: 0.6rem; margin-top: auto; }
  .hl-bundles__price { font-family: var(--font-body--family); font-weight: 700; font-size: 1.3rem; color: var(--hl-green); }
  .hl-bundles__compare { opacity: 0.5; }
  .hl-bundles__btn { margin-top: 0.4rem; }

  @media (max-width: 990px) {
    .hl-bundles__grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 560px) {
    .hl-bundles__card { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homelyte Bundles",
  "tag": "section",
  "class": "hl-section-wrapper",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Buy More, Save More" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Bundle & Save" },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Save 15%" },
        { "type": "text", "id": "title", "label": "Title", "default": "Kitchen Bundle" },
        { "type": "richtext", "id": "items", "label": "Items included", "default": "<ul><li>Oil Bottle</li><li>Spice Organizer</li><li>Egg Holder</li></ul>" },
        { "type": "text", "id": "price", "label": "Bundle price", "default": "₹2,799" },
        { "type": "text", "id": "compare_price", "label": "Compare price", "default": "₹3,297" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Bundle" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homelyte Bundles",
      "blocks": [
        { "type": "bundle", "settings": { "title": "Kitchen Bundle", "badge": "Save 15%", "items": "<ul><li>Oil Bottle</li><li>Spice Organizer</li><li>Egg Holder</li></ul>" } },
        { "type": "bundle", "settings": { "title": "Bathroom Bundle", "badge": "Save 15%", "items": "<ul><li>Under Sink Organizer</li><li>Storage Basket</li></ul>", "price": "₹3,199", "compare_price": "₹3,764" } }
      ]
    }
  ]
}
{% endschema %}
