{%- liquid
  assign s = section.settings
-%}

<div
  class="hl-ig hl-section color-{{ s.color_scheme }}"
  style="--hl-pt: {{ s.padding_top }}px; --hl-pb: {{ s.padding_bottom }}px;"
>
  <div class="hl-container">
    <div class="hl-section__head hl-section__head--center">
      {%- if s.eyebrow != blank -%}<span class="hl-eyebrow" data-hl-reveal>{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="hl-heading hl-heading--lg" data-hl-reveal>{{ s.heading }}</h2>{%- endif -%}
      {%- if s.handle != blank -%}
        <a class="hl-ig__handle" href="{{ s.follow_link | default: '#' }}" data-hl-reveal>{{ s.handle }}</a>
      {%- endif -%}
    </div>

    <ul class="hl-ig__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="hl-ig__item" data-hl-reveal style="--hl-reveal-delay: {{ forloop.index0 | times: 50 }}ms;" {{ block.shopify_attributes }}>
          <a class="hl-ig__link" href="{{ block.settings.link | default: s.follow_link | default: '#' }}" {% if block.settings.link != blank or s.follow_link != blank %}target="_blank" rel="noopener"{% endif %}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '250,400,600,700', sizes: '(min-width:750px) 33vw, 50vw', class: 'hl-ig__img', alt: 'Homelyte on Instagram' }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'hl-ig__img' }}
            {%- endif -%}
            <span class="hl-ig__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if s.follow_label != blank -%}
      <div class="hl-ig__cta" data-hl-reveal>
        <a class="hl-btn hl-btn--primary" href="{{ s.follow_link | default: '#' }}" target="_blank" rel="noopener">{{ s.follow_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hl-ig__handle {
    font-family: var(--font-body--family);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }
  .hl-ig__handle:hover { text-decoration: underline; }

  .hl-ig__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(8px, 1.2vw, 16px);
  }

  .hl-ig__link {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: var(--hl-radius);
    overflow: hidden;
  }

  .hl-ig__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s var(--hl-ease); }
  .hl-ig__link:hover .hl-ig__img { transform: scale(1.08); }

  .hl-ig__icon {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #fff;
    background: rgb(17 17 17 / 0%);
    opacity: 0;
    transition: opacity 0.4s var(--hl-ease), background-color 0.4s var(--hl-ease);
  }

  .hl-ig__link:hover .hl-ig__icon { opacity: 1; background: rgb(17 17 17 / 35%); }
  .hl-ig__icon svg { width: 34px; height: 34px; }

  .hl-ig__cta { display: flex; justify-content: center; margin-top: clamp(24px, 3vw, 44px); }

  @media (max-width: 560px) {
    .hl-ig__grid { gap: 8px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homelyte Instagram",
  "tag": "section",
  "class": "hl-section-wrapper",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@homelyte" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Follow the Homelyte Life" },
    { "type": "text", "id": "handle", "label": "Handle", "default": "@homelyte" },
    { "type": "text", "id": "follow_label", "label": "Follow button label", "default": "Follow us on Instagram" },
    { "type": "url", "id": "follow_link", "label": "Instagram URL" },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homelyte Instagram",
      "blocks": [
        { "type": "post" }, { "type": "post" }, { "type": "post" },
        { "type": "post" }, { "type": "post" }, { "type": "post" },
        { "type": "post" }, { "type": "post" }, { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
