{%- liquid
  assign s = section.settings
  assign overlay = s.overlay_opacity | divided_by: 100.0
-%}

<div
  class="hl-video hl-section color-{{ s.color_scheme }}"
  style="--hl-video-height: {{ s.height }}svh; --hl-overlay: {{ overlay }}; --hl-pt: {{ s.padding_top }}px; --hl-pb: {{ s.padding_bottom }}px;"
>
  <div class="hl-video__media">
    {%- if s.video != blank -%}
      {{
        s.video
        | video_tag:
          image_size: '1600x',
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'hl-video__el'
      }}
    {%- elsif s.poster != blank -%}
      {{ s.poster | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '800,1200,1600,2000', sizes: '100vw', class: 'hl-video__poster', alt: '' }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'hl-video__poster' }}
    {%- endif -%}
    <div class="hl-video__overlay" aria-hidden="true"></div>
  </div>

  <div class="hl-video__content hl-container" data-hl-reveal>
    {%- if s.eyebrow != blank -%}<span class="hl-eyebrow hl-video__eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="hl-heading hl-heading--lg hl-video__heading">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.button_label != blank -%}
      <a class="hl-btn hl-btn--on-media hl-video__btn" href="{{ s.button_link | default: '#' }}">
        <span class="hl-video__btn-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </span>
        {{ s.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .hl-video {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: var(--hl-video-height, 70svh);
    overflow: hidden;
    padding-block: 0;
  }

  .hl-video__media { position: absolute; inset: 0; z-index: 0; }

  .hl-video__el,
  .hl-video__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hl-video__overlay {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--hl-overlay, 0.4));
  }

  .hl-video__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    padding-block: clamp(60px, 10vh, 120px);
  }

  .hl-video__eyebrow { color: #fff; opacity: 0.85; }
  .hl-video__heading { color: #fff; max-width: 18ch; }

  .hl-video__btn-icon {
    display: grid;
    place-items: center;
    width: 18px;
    height: 18px;
  }

  .hl-video__btn-icon svg { width: 14px; height: 14px; }
{% endstylesheet %}

{% schema %}
{
  "name": "Homelyte Video",
  "tag": "section",
  "class": "hl-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Watch" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Organization feels beautiful." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Watch More" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Media" },
    { "type": "video", "id": "video", "label": "Video (autoplay, muted)" },
    { "type": "image_picker", "id": "poster", "label": "Fallback poster image" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 35 },
    { "type": "range", "id": "height", "label": "Section height", "min": 45, "max": 100, "step": 1, "unit": "svh", "default": 72 },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-5" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 0 }
  ],
  "presets": [{ "name": "Homelyte Video" }]
}
{% endschema %}
