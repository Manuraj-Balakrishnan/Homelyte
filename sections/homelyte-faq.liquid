{%- liquid
  assign s = section.settings
-%}

<div
  class="hl-faq hl-section color-{{ s.color_scheme }}"
  style="--hl-pt: {{ s.padding_top }}px; --hl-pb: {{ s.padding_bottom }}px;"
>
  <div class="hl-container hl-faq__layout">
    <div class="hl-faq__head" data-hl-reveal>
      {%- if s.eyebrow != blank -%}<span class="hl-eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="hl-heading hl-heading--lg">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.subtext != blank -%}<div class="hl-text hl-faq__subtext">{{ s.subtext }}</div>{%- endif -%}
    </div>

    <div class="hl-faq__list">
      {%- for block in section.blocks -%}
        <details class="hl-faq__item" data-hl-reveal style="--hl-reveal-delay: {{ forloop.index0 | times: 50 }}ms;" {% if forloop.first and s.open_first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="hl-faq__q">
            <span>{{ block.settings.question }}</span>
            <span class="hl-faq__icon" aria-hidden="true"></span>
          </summary>
          <div class="hl-faq__a hl-text">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{%- capture faq_schema -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | strip_html | json }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ block.settings.answer | strip_html | json }} }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
{%- endcapture -%}
<script type="application/ld+json">{{ faq_schema }}</script>

{% stylesheet %}
  .hl-faq__layout {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(28px, 5vw, 80px);
    align-items: start;
  }

  .hl-faq__head { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: calc(var(--header-height, 0px) + 24px); }
  .hl-faq__subtext { max-width: 38ch; }

  .hl-faq__list { display: flex; flex-direction: column; }

  .hl-faq__item {
    border-bottom: 1px solid var(--color-border);
  }

  .hl-faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.4rem 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    color: var(--color-foreground-heading);
  }

  .hl-faq__q::-webkit-details-marker { display: none; }

  .hl-faq__icon {
    position: relative;
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
  }

  .hl-faq__icon::before,
  .hl-faq__icon::after {
    content: '';
    position: absolute;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform 0.35s var(--hl-ease), opacity 0.35s var(--hl-ease);
  }

  .hl-faq__icon::before { top: 50%; left: 0; width: 100%; height: 2px; transform: translateY(-50%); }
  .hl-faq__icon::after { left: 50%; top: 0; width: 2px; height: 100%; transform: translateX(-50%); }

  .hl-faq__item[open] .hl-faq__icon::after { transform: translateX(-50%) scaleY(0); opacity: 0; }

  .hl-faq__a {
    padding: 0 0 1.4rem;
    max-width: 60ch;
  }

  .hl-faq__a :is(p, ul, ol) { margin: 0 0 0.6rem; }
  .hl-faq__a :is(p, ul, ol):last-child { margin-bottom: 0; }

  @media (prefers-reduced-motion: no-preference) {
    .hl-faq__item[open] .hl-faq__a {
      animation: hl-faq-reveal 0.4s var(--hl-ease);
    }
    @keyframes hl-faq-reveal {
      from { opacity: 0; transform: translateY(-6px); }
      to { opacity: 1; transform: none; }
    }
  }

  @media (max-width: 749px) {
    .hl-faq__layout { grid-template-columns: 1fr; }
    .hl-faq__head { position: static; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homelyte FAQ",
  "tag": "section",
  "class": "hl-section-wrapper",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Good to Know" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>Everything you need to know about ordering, shipping and caring for your Homelyte products.</p>" },
    { "type": "checkbox", "id": "open_first", "label": "Open first item by default", "default": true },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Orders are dispatched within 24 hours and typically arrive in 3–5 business days. Free shipping on orders above ₹999.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homelyte FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Orders ship within 24 hours and arrive in 3–5 business days. Free shipping above ₹999.</p>" } },
        { "type": "faq", "settings": { "question": "What is your returns policy?", "answer": "<p>Enjoy 7 days easy returns on unused items in original packaging.</p>" } },
        { "type": "faq", "settings": { "question": "What materials are used?", "answer": "<p>Our products use premium, food-grade, BPA-free materials built to last.</p>" } },
        { "type": "faq", "settings": { "question": "How do I clean my products?", "answer": "<p>Most products are easy to wipe clean or top-rack dishwasher safe. Check each product page for details.</p>" } },
        { "type": "faq", "settings": { "question": "Is there a warranty?", "answer": "<p>Yes — all Homelyte products come with a quality assurance warranty against manufacturing defects.</p>" } }
      ]
    }
  ]
}
{% endschema %}
